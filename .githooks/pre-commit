#!/usr/bin/env bash
# =============================================================================
# Neghab — Git Pre-Commit Hook
#
# Runs local quality gates before allowing a commit:
#   1. gofmt  — format check
#   2. go vet — static analysis
#   3. golangci-lint — comprehensive linting
#   4. govulncheck — vulnerability scan
#   5. go test -short — fast unit tests
#
# Install:
#   cp .githooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use the Makefile target:
#   make setup-hooks
# =============================================================================

set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

pass_msg() { echo -e "  ${GREEN}✓${NC} $1"; }
fail_msg() { echo -e "  ${RED}✗${NC} $1"; }
info_msg() { echo -e "  ${CYAN}→${NC} $1"; }

# ── Track failures ────────────────────────────────────────────────────────
FAILURES=0
check() {
    local desc="$1"; shift
    info_msg "$desc"
    if "$@"; then
        pass_msg "$desc passed"
    else
        fail_msg "$desc FAILED"
        FAILURES=$((FAILURES + 1))
    fi
}

echo ""
echo -e "${CYAN}══════════════════════════════════════════════${NC}"
echo -e "${CYAN}  Neghab — Pre-Commit Checks${NC}"
echo -e "${CYAN}══════════════════════════════════════════════${NC}"
echo ""

# ── 0. Check required tools ──────────────────────────────────────────────
for tool in go golangci-lint govulncheck; do
    if ! command -v "$tool" &>/dev/null; then
        echo -e "  ${YELLOW}⚠${NC}  $tool not found — skipping $tool checks"
    fi
done
echo ""

# ── 1. gofmt ─────────────────────────────────────────────────────────────
check "gofmt (format check)" gofmt -l . 2>&1
if [ "$(gofmt -l . 2>/dev/null | wc -l)" -gt 0 ]; then
    echo -e "  ${YELLOW}⚠${NC}  Run 'gofmt -w .' to fix formatting"
fi

# ── 2. go vet ────────────────────────────────────────────────────────────
check "go vet" go vet ./...

# ── 3. golangci-lint ────────────────────────────────────────────────────
if command -v golangci-lint &>/dev/null; then
    check "golangci-lint" golangci-lint run ./...
else
    echo -e "  ${YELLOW}⚠${NC}  golangci-lint not installed — skipping"
fi

# ── 4. govulncheck ──────────────────────────────────────────────────────
if command -v govulncheck &>/dev/null; then
    check "govulncheck" govulncheck ./...
else
    echo -e "  ${YELLOW}⚠${NC}  govulncheck not installed — skipping"
fi

# ── 5. Unit tests (fast mode) ───────────────────────────────────────────
check "go test -short" go test -short -count=1 -timeout=60s ./...

# ── Result ───────────────────────────────────────────────────────────────
echo ""
if [ "$FAILURES" -eq 0 ]; then
    echo -e "${GREEN}══════════════════════════════════════════════${NC}"
    echo -e "${GREEN}  All checks passed ✓${NC}"
    echo -e "${GREEN}══════════════════════════════════════════════${NC}"
    echo ""
    exit 0
else
    echo -e "${RED}══════════════════════════════════════════════${NC}"
    echo -e "${RED}  ${FAILURES} check(s) failed — commit blocked${NC}"
    echo -e "${RED}══════════════════════════════════════════════${NC}"
    echo ""
    exit 1
fi
